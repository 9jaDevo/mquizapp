# =============================================================================
# mQuiz API — Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# ----- Database -----
# MariaDB on local XAMPP. Shared with PHP backend during migration.
DATABASE_URL="mysql://root:@localhost:3306/mquiz_d5bueportal"

# ----- Firebase Admin SDK -----
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
# Replace literal \n inside the key with real newlines, or wrap the whole value in quotes with \n preserved.
FIREBASE_PRIVATE_KEY=""

# ----- Redis -----
REDIS_URL="redis://localhost:6379"

# ----- OpenAI -----
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
OPENAI_MINI_MODEL="gpt-4o-mini"

# ----- Paystack -----
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""
PAYSTACK_WEBHOOK_SECRET=""

# ----- Cloudinary -----
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ----- App -----
PORT=3000
NODE_ENV="development"
APP_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3001"
MOBILE_APP_BUNDLE="com.mquiz.learn"
