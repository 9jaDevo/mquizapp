  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tbl_user_lives")
}

model BoosterType {
  id          Int     @id @default(autoincrement())
  code        String  @unique @db.VarChar(64)
  name        String  @db.VarChar(128)
