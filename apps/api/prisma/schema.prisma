generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int      @id @default(autoincrement()) @db.UnsignedInt
  firebaseId         String   @map("firebase_id") @db.LongText
  name               String   @default("") @db.VarChar(128)
  email              String   @db.VarChar(128)
  countryCode        String?  @map("country_code") @db.VarChar(3)
  countryName        String?  @map("country_name") @db.VarChar(100)
  continent          String?  @db.VarChar(50)
  regionAutoDetected Boolean? @default(true) @map("region_auto_detected")
  mobile             String   @db.VarChar(32)
  type               String   @db.VarChar(16)
  profile            String   @db.VarChar(128)
  fcmId              String?  @map("fcm_id") @db.VarChar(1024)
  webFcmId           String?  @map("web_fcm_id") @db.VarChar(1024)
  coins              Int      @default(0)
  referCode          String?  @map("refer_code") @db.VarChar(128)
  friendsCode        String?  @map("friends_code") @db.VarChar(128)
  removeAds          Int      @default(0) @map("remove_ads") @db.TinyInt
  dailyAdsCounter    Int      @default(0) @map("daily_ads_counter")
  dailyAdsDate       DateTime @default(dbgenerated("('2023-10-19')")) @map("daily_ads_date") @db.Date
  status             Int?     @default(0) @db.UnsignedInt
  dateRegistered     DateTime @map("date_registered") @db.DateTime(0)
  apiToken           String   @map("api_token") @db.LongText
  appLanguage        String?  @map("app_language") @db.VarChar(512)
  webLanguage        String?  @map("web_language") @db.VarChar(512)
  ageGroup           String?  @map("age_group") @db.VarChar(20)

  @@index([email, mobile], map: "email")
  @@index([fcmId(length: 333)], map: "fcm_id")
  @@index([firebaseId(length: 333)], map: "firebase_id")
  @@index([continent], map: "idx_continent")
  @@index([countryCode], map: "idx_country_code")
  @@index([webFcmId(length: 333)], map: "web_fcm_id")
  @@map("tbl_users")
}

model Category {
  id           Int     @id @default(autoincrement())
  languageId   Int     @default(0) @map("language_id")
  categoryName String  @map("category_name") @db.VarChar(250)
  slug         String? @db.VarChar(250)
  type         Int
  isPremium    Int     @default(0) @map("is_premium") @db.TinyInt
  coins        Int     @default(0)
  image        String? @db.Text
  rowOrder     Int     @map("row_order")
  status       Int     @default(1) @db.TinyInt

  @@index([languageId], map: "language_id")
  @@index([status], map: "idx_category_status")
  @@map("tbl_category")
}

model Subcategory {
  id              Int     @id @default(autoincrement())
  languageId      Int     @default(0) @map("language_id")
  maincatId       Int     @map("maincat_id")
  subcategoryName String  @map("subcategory_name") @db.VarChar(250)
  slug            String? @db.VarChar(250)
  image           String? @db.Text
  status          Int     @default(1) @db.TinyInt
  isPremium       Int     @default(0) @map("is_premium") @db.TinyInt
  coins           Int     @default(0)
  rowOrder        Int     @map("row_order")

  @@index([languageId], map: "language_id")
  @@index([maincatId], map: "maincat_id")
  @@map("tbl_subcategory")
}

model UserBookmark {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  userId     Int      @map("user_id") @db.UnsignedInt
  questionId Int      @map("question_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([userId, questionId], name: "uq_user_question", map: "uq_user_question")
  @@index([userId], map: "idx_bookmarks_user_id")
  @@index([questionId], map: "idx_bookmarks_question_id")
  @@map("tbl_user_bookmarks")
}

model Question {
  id           Int     @id @default(autoincrement())
  category     Int
  subcategory  Int
  languageId   Int     @default(0) @map("language_id")
  image        String  @db.VarChar(512)
  question     String  @db.Text
  questionType Int     @map("question_type") @db.TinyInt
  optiona      String  @db.Text
  optionb      String  @db.Text
  optionc      String  @db.Text
  optiond      String  @db.Text
  optione      String? @db.Text
  answer       String  @db.Text
  level        Int
  note         String  @db.Text
  aiGenerated  Int     @default(0) @map("ai_generated") @db.TinyInt

  @@index([category], map: "category")
  @@index([languageId], map: "language_id")
  @@index([subcategory], map: "subcategory")
  @@index([aiGenerated], map: "idx_question_ai_generated")
  @@map("tbl_question")
}

model AiQuestion {
  id            BigInt   @id @default(autoincrement())
  languageId    Int      @default(0) @map("language_id")
  quizType      Int      @default(0) @map("quiz_type")
  contestId     Int      @default(0) @map("contest_id")
  examId        Int      @default(0) @map("exam_id")
  category      Int
  subcategory   Int      @default(0)
  level         Int      @default(0)
  questionType  Int      @default(0) @map("question_type")
  answerType    Int      @default(0) @map("answer_type")
  question      String   @db.Text
  options       String   @db.LongText
  correctAnswer String   @map("correct_answer") @db.VarChar(50)
  marks         Int      @default(0)
  status        Int      @default(0)
  note          String?  @db.VarChar(255)
  dateTime      DateTime @map("date_time") @db.DateTime(0)

  @@map("tbl_ai_questions")
}

model AiGenerationLog {
  id               Int      @id @default(autoincrement())
  adminUserId      Int?     @map("admin_user_id")
  topic            String   @db.VarChar(255)
  categoryId       Int      @default(0) @map("category_id")
  difficulty       String   @default("medium") @db.VarChar(20)
  count            Int      @default(0)
  tokensUsed       Int      @default(0) @map("tokens_used")
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  model            String   @default("") @db.VarChar(64)
  createdAt        DateTime @default(now()) @map("created_at") @db.DateTime(0)

  @@index([createdAt], map: "idx_ai_gen_log_created")
  @@map("tbl_ai_generation_logs")
}

model DailyStreak {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  uid             String?   @db.VarChar(255)
  lastLoginDate   DateTime? @map("last_login_date") @db.Date
  streakCount     Int?      @default(0) @map("streak_count")
  maxStreak       Int?      @default(0) @map("max_streak")
  coinEarnedToday Int?      @default(0) @map("coin_earned_today")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([updatedAt], map: "idx_updated")
  @@index([userId, lastLoginDate], map: "idx_user_date")
  @@index([userId], map: "idx_user_id")
  @@map("tbl_daily_streak")
}

model Tracker {
  id     Int      @id @default(autoincrement())
  userId Int      @map("user_id")
  uid    String   @db.Text
  points String   @db.VarChar(255)
  type   String   @db.Text
  status Int      @db.TinyInt
  date   DateTime @db.Date

  @@index([userId], map: "user_id")
  @@map("tbl_tracker")
}

model LeaderboardDaily {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  score          Int
  correctAnswers Int      @default(0) @map("correct_answers")
  totalAnswers   Int      @default(0) @map("total_answers")
  dateCreated    DateTime @map("date_created") @db.DateTime(0)

  @@index([userId, dateCreated], map: "user_id")
  @@map("tbl_leaderboard_daily")
}

model LeaderboardWeekly {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  score       Int      @default(0)
  weekNumber  Int      @map("week_number")
  year        Int
  lastUpdated DateTime @map("last_updated") @db.DateTime(0)
  dateCreated DateTime @map("date_created") @db.DateTime(0)

  @@unique([userId, weekNumber, year], map: "unique_user_week")
  @@index([weekNumber, year, score], map: "idx_ranking")
  @@index([score], map: "idx_score")
  @@index([userId], map: "idx_user_id")
  @@index([weekNumber, year], map: "idx_week_year")
  @@map("tbl_leaderboard_weekly")
}

model LeaderboardMonthly {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  score       Int
  lastUpdated DateTime @map("last_updated") @db.DateTime(0)
  dateCreated DateTime @map("date_created") @db.DateTime(0)

  @@index([userId, dateCreated], map: "user_id")
  @@map("tbl_leaderboard_monthly")
}

model FraudDetection {
  id               Int                                 @id @default(autoincrement())
  userId           Int                                 @map("user_id")
  uid              String?                             @db.VarChar(255)
  detection_type   tbl_fraud_detection_detection_type? @default(unusual_pattern)
  reason           String                              @db.VarChar(255)
  severity         tbl_fraud_detection_severity?       @default(low)
  action_taken     tbl_fraud_detection_action_taken?   @default(none)
  action_date      DateTime?                           @db.Timestamp(0)
  metadata         String?                             @db.LongText
  resolved         Int?                                @default(0) @db.TinyInt
  resolvedAt       DateTime?                           @map("resolved_at") @db.Timestamp(0)
  resolution_notes String?                             @db.VarChar(500)
  createdAt        DateTime?                           @default(now()) @map("created_at") @db.Timestamp(0)

  @@index([resolved], map: "idx_resolved")
  @@index([severity], map: "idx_severity")
  @@index([userId], map: "idx_user_id")
  @@index([userId, detection_type], map: "idx_user_type")
  @@map("tbl_fraud_detection")
}

model Settings {
  id      Int    @id @default(autoincrement())
