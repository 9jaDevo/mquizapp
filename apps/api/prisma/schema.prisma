  @@unique([post_id, tag], map: "post_tag_unique")
  @@index([post_id], map: "post_id")
  @@index([tag], map: "tag")
}

model tbl_blog_posts {
  id                     Int                     @id @default(autoincrement())
  title                  String                  @db.VarChar(255)
  slug                   String                  @unique(map: "slug") @db.VarChar(255)
  excerpt                String?                 @db.LongText
  content                String                  @db.LongText
  featured_image         String?                 @db.LongText
  category_id            Int?
  author_id              Int?
  featured               Boolean?                @default(false)
  status                 tbl_blog_posts_status?  @default(draft)
  views                  Int?                    @default(0)
  meta_title             String?                 @db.VarChar(255)
  meta_description       String?                 @db.LongText
  meta_keywords          String?                 @db.LongText
  publish_date           DateTime?               @db.DateTime(0)
  created_at             DateTime?               @default(now()) @db.Timestamp(0)
  updated_at             DateTime?               @default(now()) @db.Timestamp(0)
  tbl_blog_comments      tbl_blog_comments[]
  tbl_blog_post_tags     tbl_blog_post_tags[]
  tbl_blog_authors       tbl_blog_authors?       @relation(fields: [author_id], references: [id], onUpdate: Restrict, map: "fk_blog_author")
  tbl_blog_categories    tbl_blog_categories?    @relation(fields: [category_id], references: [id], onUpdate: Restrict, map: "fk_blog_category")
  tbl_blog_seo_analytics tbl_blog_seo_analytics?

  @@index([author_id], map: "author_id")
  @@index([category_id], map: "category_id")
  @@index([featured], map: "featured")
  @@index([publish_date], map: "publish_date")
  @@index([status], map: "status")
}

