{
  "info": {
    "_postman_id": "mquiz-api-v2-collection",
    "name": "mQuiz API v2",
    "description": "mQuiz Platform — NestJS Backend API\n\nSetup:\n1. Import this collection AND mQuiz_Dev.postman_environment.json\n2. Set `firebaseToken` in the environment (get from Firebase Auth SDK or mQuiz app dev tools)\n3. All requests auto-attach Bearer token from the environment variable\n\nResponse envelope: All responses follow { success: true/false, data: {}, message: '' }\nThe collection-level test script verifies this envelope on every request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{firebaseToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global test: verify the standard response envelope on every response",
          "if (pm.response.code !== 204) {",
          "  try {",
          "    const json = pm.response.json();",
          "    pm.test('Response has success field', () => {",
          "      pm.expect(json).to.have.property('success');",
          "    });",
          "    pm.test('Response has message field', () => {",
          "      pm.expect(json).to.have.property('message');",
          "    });",
          "    if (json.success) {",
          "      pm.test('Successful response has data field', () => {",
          "        pm.expect(json).to.have.property('data');",
          "      });",
          "    } else {",
          "      pm.test('Error response has error field', () => {",
          "        pm.expect(json).to.have.property('error');",
          "      });",
          "    }",
          "  } catch (e) {",
          "    pm.test('Response is valid JSON', () => { pm.expect.fail('Response is not JSON'); });",
          "  }",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "{{baseUrl}}",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login / Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Login successful', () => pm.expect(json.success).to.be.true);",
                  "if (json.data && json.data.user) {",
                  "  pm.environment.set('userId', json.data.user.id);",
                  "  pm.environment.set('userFirebaseId', json.data.user.firebaseId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/v2/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["v2", "auth", "login"]
            },
            "description": "Register or login via Firebase token.\nFirebase token is attached automatically via collection-level auth.\nBody is empty — user identity comes from the token."
          }
        },
        {
          "name": "Guest Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Guest user created', () => pm.expect(json.success).to.be.true);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{ \"deviceId\": \"test-device-001\" }",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/v2/auth/guest",
              "host": ["{{baseUrl}}"],
              "path": ["v2", "auth", "guest"]
            }
          }
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v2/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["v2", "auth", "refresh-token"]
            }
          }
        }
      ]
    },
