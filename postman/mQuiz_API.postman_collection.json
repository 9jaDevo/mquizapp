              "path": ["v2", "quiz", "questions"],
              "query": [
                { "key": "type", "value": "1", "description": "1=quiz_zone, 2=fun_learn, 3=guess_word" },
                { "key": "category_id", "value": "{{categoryId}}" },
                { "key": "subcategory_id", "value": "", "disabled": true },
                { "key": "language_id", "value": "", "disabled": true },
                { "key": "level", "value": "", "disabled": true, "description": "1=easy, 2=medium, 3=hard" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Returns randomized questions for a quiz session.\nIMPORTANT: correctAnswer must NOT be in the response."
          }
